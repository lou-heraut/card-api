    affiliation: "INRAE, UR RiverLy, Villeurbanne, France"
version: "0.2.0"
date-released: "2026-07-22"
repository-code: "https://github.com/lou-heraut/card-api"
license: "GPL-3.0-or-later"
keywords:
  - hydrologie
  - débits
  - étiage
  - tendance
  - Mann-Kendall
  - Hub'Eau
