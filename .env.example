# Copier en `.env` (gitignoré) et adapter ; docker compose le lit
# automatiquement ; rien d'autre à éditer.

# Domaine public de l'API, ou IP de la VM en attendant un domaine
# (une IP = HTTP seulement, aucun certificat possible sur une IP nue).
# Une seule source de vérité : « make apache » génère le vhost avec,
# et le mode Caddy autoportant le lit aussi. Changement de domaine =
# éditer ici puis relancer make apache (et certbot si vrai domaine).
DOMAIN=api.example.org

# Port hôte (boucle locale) où le conteneur expose l'API ; à changer
# si 8000 est déjà pris sur la VM. make apache le lit aussi.
# CARD_API_PORT=8000

# VM nue sans serveur web : décommenter pour lancer aussi le frontal
# Caddy (ports 80/443, HTTPS automatique, nom de domaine requis).
# VM avec Apache déjà en place : laisser commenté, faire make apache.
# COMPOSE_PROFILES=caddy

# Sel du hachage des IP dans le journal d'usage : le FIXER en prod
# (statistiques d'utilisateurs distincts stables entre redémarrages).
# Générer : openssl rand -hex 16
CARD_API_SALT=changez-moi

# Quotas par IP et par minute (défauts raisonnables)
CARD_API_RATE_COMPUTE=10
CARD_API_RATE_LIGHT=60

# Plafonds des demandes : jusqu'aux plafonds SYNC la réponse est
# immédiate ; au-delà (et jusqu'aux plafonds JOB) la demande devient
# un job (202 + ticket, cf. /v1/jobs). À dimensionner selon la VM.
CARD_API_SYNC_STATIONS=10
CARD_API_SYNC_CARDS=20
CARD_API_JOB_STATIONS=100
CARD_API_JOB_CARDS=50
# Rétention des résultats de jobs (jours) et taille maximale de la file
CARD_API_JOB_TTL_DAYS=7
CARD_API_JOB_QUEUE_MAX=100

# Plafonds des porteurs de clé de priorité (make key name="...")
CARD_API_PRIORITY_STATIONS=1000
CARD_API_PRIORITY_CARDS=226

# Révisions de card et stase embarquées dans l'image (tag ou commit)
CARD_REF=main
STASE_REF=main
