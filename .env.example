# Copier en `.env` (gitignoré) et adapter — docker compose le lit
# automatiquement ; rien d'autre à éditer.

# Nom de domaine public de l'API (certificat HTTPS automatique)
DOMAIN=api.example.org

# Sel du hachage des IP dans le journal d'usage : le FIXER en prod
# (statistiques d'utilisateurs distincts stables entre redémarrages).
# Générer : openssl rand -hex 16
CARD_API_SALT=changez-moi

# Quotas par IP et par minute (défauts raisonnables)
CARD_API_RATE_COMPUTE=10
CARD_API_RATE_LIGHT=60

# Révisions de card et stase embarquées dans l'image (tag ou commit)
CARD_REF=main
STASE_REF=main
